# ==========================================
# PostgreSQL Database Configuration
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin

# Service Specific Databases
AUTH_DB=authdb
USER_DB=userdb
EVENT_DB=eventdb
AUDIT_DB=auditdb

# Application Connection Strings (for Spring Boot application.yml properties)
AUTH_DB_URL=jdbc:postgresql://localhost:5432/authdb
USER_DB_URL=jdbc:postgresql://localhost:5433/userdb
EVENT_DB_URL=jdbc:postgresql://localhost:5434/eventdb
AUDIT_DB_URL=jdbc:postgresql://localhost:5435/auditdb

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# Kafka / Zookeeper Configuration
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ZOOKEEPER_CONNECT=localhost:2181

# ==========================================
# API Gateway & Auth Configuration
# ==========================================
# 256-bit (32 byte) minimum JWT Secret Base64-Encoded
JWT_SECRET=ZGV2ZWxvcG1lbnQtc2VjcmV0LWtleS1tdXN0LWJlLWF0LWxlYXN0LTMyLWJ5dGVzCg==
